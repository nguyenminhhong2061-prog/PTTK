# =============================================
# Environment Variables Template
# Copy file này thành .env và điền giá trị thực
# =============================================

# --- General ---
COMPOSE_PROJECT_NAME=quiz-system
ENVIRONMENT=development

# --- Database (MySQL) ---
DB_USER=root
DB_PASSWORD=changeme

# --- Service Ports (host) ---
EXAM_SERVICE_PORT=5001
SUBMISSION_SERVICE_PORT=5002
STATISTICS_SERVICE_PORT=5003
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- Database Ports (host) ---
EXAM_DB_PORT=3306
SUBMISSION_DB_PORT=3307

# --- Nếu cần thêm ---
# JWT_SECRET=your-jwt-secret
